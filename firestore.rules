rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read everywhere
    match /{document=**} {
      allow read: if true;
    }
    // Only authenticated (Discord-verified) users can write
    match /config/{doc} {
      allow write: if request.auth != null;
    }
    match /suggestions/{doc} {
      // Anyone can create a suggestion or upvote (increment only)
      allow create: if true;
      allow update: if request.resource.data.votes == resource.data.votes + 1
                    && request.auth == null; // vote without login
      allow update, delete: if request.auth != null; // admin can do anything
    }
    match /pastBooks/{doc} {
      allow write: if request.auth != null;
    }
  }
}
